    chu rl_get_music_time_played(music);
}

# ================================================================
# UTILITY
# ================================================================
kar get_random_value(min: adad, max: adad) -> adad {
    chu rl_get_random_value(min, max);
}
kar set_random_seed(seed: adad) -> khali {
    rl_set_random_seed(seed);
}
kar take_screenshot(path: lafz) -> khali {
    rl_take_screenshot(path);
}
kar open_url(url: lafz) -> khali {
    rl_open_url(url);
}

# ================================================================
