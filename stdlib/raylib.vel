# ================================================================
# WINDOW
# ================================================================
kar init_window(w: adad, h: adad, title: lafz) -> khali {
    rl_init_window(w, h, title);
}
kar close_window() -> khali {
    rl_close_window();
}
kar window_should_close() -> adad {
    chu rl_window_should_close();
}
kar is_window_ready() -> adad {
    chu rl_is_window_ready();
}
kar is_window_fullscreen() -> adad {
    chu rl_is_window_fullscreen();
}
kar is_window_hidden() -> adad {
    chu rl_is_window_hidden();
}
kar is_window_minimized() -> adad {
    chu rl_is_window_minimized();
}
kar is_window_maximized() -> adad {
    chu rl_is_window_maximized();
}
kar is_window_focused() -> adad {
    chu rl_is_window_focused();
}
kar is_window_resized() -> adad {
    chu rl_is_window_resized();
}
kar set_window_state(flags: adad) -> khali {
    rl_set_window_state(flags);
}
kar clear_window_state(flags: adad) -> khali {
    rl_clear_window_state(flags);
}
kar toggle_fullscreen() -> khali {
    rl_toggle_fullscreen();
}
kar toggle_borderless_windowed() -> khali {
    rl_toggle_borderless_windowed();
}
kar maximize_window() -> khali {
    rl_maximize_window();
}
kar minimize_window() -> khali {
    rl_minimize_window();
}
kar restore_window() -> khali {
    rl_restore_window();
}
kar set_window_title(title: lafz) -> khali {
    rl_set_window_title(title);
}
kar set_window_position(x: adad, y: adad) -> khali {
    rl_set_window_position(x, y);
}
kar set_window_monitor(monitor: adad) -> khali {
    rl_set_window_monitor(monitor);
}
kar set_window_min_size(w: adad, h: adad) -> khali {
    rl_set_window_min_size(w, h);
}
kar set_window_max_size(w: adad, h: adad) -> khali {
    rl_set_window_max_size(w, h);
}
kar set_window_size(w: adad, h: adad) -> khali {
    rl_set_window_size(w, h);
}
kar set_window_opacity(opacity: ashari) -> khali {
    rl_set_window_opacity(opacity);
}
kar set_window_focused() -> khali {
    rl_set_window_focused();
}
kar get_screen_width() -> adad {
    chu rl_get_screen_width();
}
kar get_screen_height() -> adad {
    chu rl_get_screen_height();
}
kar get_render_width() -> adad {
    chu rl_get_render_width();
}
kar get_render_height() -> adad {
    chu rl_get_render_height();
}
kar get_monitor_count() -> adad {
    chu rl_get_monitor_count();
}
kar get_current_monitor() -> adad {
    chu rl_get_current_monitor();
}
kar get_monitor_width(monitor: adad) -> adad {
    chu rl_get_monitor_width(monitor);
}
kar get_monitor_height(monitor: adad) -> adad {
    chu rl_get_monitor_height(monitor);
}
kar get_monitor_refresh_rate(monitor: adad) -> adad {
    chu rl_get_monitor_refresh_rate(monitor);
}
kar get_monitor_name(monitor: adad) -> lafz {
    chu rl_get_monitor_name(monitor);
}
kar set_clipboard_text(text: lafz) -> khali {
    rl_set_clipboard_text(text);
}
kar get_clipboard_text() -> lafz {
    chu rl_get_clipboard_text();
}
kar enable_event_waiting() -> khali {
    rl_enable_event_waiting();
}
kar disable_event_waiting() -> khali {
    rl_disable_event_waiting();
}

# ================================================================
# TIMING
# ================================================================
kar set_target_fps(fps: adad) -> khali {
    rl_set_target_fps(fps);
}
kar get_fps() -> adad {
    chu rl_get_fps();
}
kar get_frame_time() -> ashari {
    chu rl_get_frame_time();
}
kar get_time() -> ashari {
    chu rl_get_time();
}
kar wait_time(seconds: ashari) -> khali {
    rl_wait_time(seconds);
}

# ================================================================
# CONFIG
# ================================================================
kar set_config_flags(flags: adad) -> khali {
    rl_set_config_flags(flags);
}
kar set_trace_log_level(level: adad) -> khali {
    rl_set_trace_log_level(level);
}
kar set_exit_key(key: adad) -> khali {
    rl_set_exit_key(key);
}

# ================================================================
# DRAWING PIPELINE
# ================================================================
kar clear_background(color: adad) -> khali {
    rl_clear_background(color);
}
kar begin_drawing() -> khali {
    rl_begin_drawing();
}
kar end_drawing() -> khali {
    rl_end_drawing();
}
kar begin_mode2d(cam: adad) -> khali {
    rl_begin_mode2d(cam);
}
kar end_mode2d() -> khali {
    rl_end_mode2d();
}
kar begin_mode3d(cam: adad) -> khali {
    rl_begin_mode3d(cam);
}
kar end_mode3d() -> khali {
    rl_end_mode3d();
}
kar begin_texture_mode(target: adad) -> khali {
    rl_begin_texture_mode(target);
}
kar end_texture_mode() -> khali {
    rl_end_texture_mode();
}
kar begin_shader_mode(shader: adad) -> khali {
    rl_begin_shader_mode(shader);
}
kar end_shader_mode() -> khali {
    rl_end_shader_mode();
}
kar begin_blend_mode(mode: adad) -> khali {
    rl_begin_blend_mode(mode);
}
kar end_blend_mode() -> khali {
    rl_end_blend_mode();
}
kar begin_scissor_mode(x: adad, y: adad, w: adad, h: adad) -> khali {
    rl_begin_scissor_mode(x, y, w, h);
}
kar end_scissor_mode() -> khali {
    rl_end_scissor_mode();
}

# ================================================================
# 2D SHAPES
# ================================================================
kar draw_pixel(x: adad, y: adad, color: adad) -> khali {
    rl_draw_pixel(x, y, color);
}
kar draw_line(x1: adad, y1: adad, x2: adad, y2: adad, color: adad) -> khali {
    rl_draw_line(x1, y1, x2, y2, color);
}
kar draw_line_ex(x1: ashari, y1: ashari, x2: ashari, y2: ashari, thick: ashari, color: adad) -> khali {
    rl_draw_line_ex(x1, y1, x2, y2, thick, color);
}
kar draw_line_bezier(x1: ashari, y1: ashari, x2: ashari, y2: ashari, thick: ashari, color: adad) -> khali {
    rl_draw_line_bezier(x1, y1, x2, y2, thick, color);
}
kar draw_circle(x: adad, y: adad, radius: ashari, color: adad) -> khali {
    rl_draw_circle(x, y, radius, color);
}
kar draw_circle_sector(cx: ashari, cy: ashari, radius: ashari, start_angle: ashari, end_angle: ashari, segments: adad, color: adad) -> khali {
    rl_draw_circle_sector(cx, cy, radius, start_angle, end_angle, segments, color);
}
kar draw_circle_sector_lines(cx: ashari, cy: ashari, radius: ashari, start_angle: ashari, end_angle: ashari, segments: adad, color: adad) -> khali {
    rl_draw_circle_sector_lines(cx, cy, radius, start_angle, end_angle, segments, color);
}
kar draw_circle_gradient(x: adad, y: adad, radius: ashari, color1: adad, color2: adad) -> khali {
    rl_draw_circle_gradient(x, y, radius, color1, color2);
}
kar draw_circle_lines(x: adad, y: adad, radius: ashari, color: adad) -> khali {
    rl_draw_circle_lines(x, y, radius, color);
}
kar draw_ellipse(x: adad, y: adad, rx: ashari, ry: ashari, color: adad) -> khali {
    rl_draw_ellipse(x, y, rx, ry, color);
}
kar draw_ellipse_lines(x: adad, y: adad, rx: ashari, ry: ashari, color: adad) -> khali {
    rl_draw_ellipse_lines(x, y, rx, ry, color);
}
kar draw_ring(cx: ashari, cy: ashari, inner_r: ashari, outer_r: ashari, start_angle: ashari, end_angle: ashari, segments: adad, color: adad) -> khali {
    rl_draw_ring(cx, cy, inner_r, outer_r, start_angle, end_angle, segments, color);
}
kar draw_ring_lines(cx: ashari, cy: ashari, inner_r: ashari, outer_r: ashari, start_angle: ashari, end_angle: ashari, segments: adad, color: adad) -> khali {
    rl_draw_ring_lines(cx, cy, inner_r, outer_r, start_angle, end_angle, segments, color);
}
kar draw_rectangle(x: adad, y: adad, w: adad, h: adad, color: adad) -> khali {
    rl_draw_rectangle(x, y, w, h, color);
}
kar draw_rectangle_gradient_v(x: adad, y: adad, w: adad, h: adad, top: adad, bottom: adad) -> khali {
    rl_draw_rectangle_gradient_v(x, y, w, h, top, bottom);
}
kar draw_rectangle_gradient_h(x: adad, y: adad, w: adad, h: adad, left: adad, right: adad) -> khali {
    rl_draw_rectangle_gradient_h(x, y, w, h, left, right);
}
kar draw_rectangle_lines(x: adad, y: adad, w: adad, h: adad, color: adad) -> khali {
    rl_draw_rectangle_lines(x, y, w, h, color);
}
kar draw_rectangle_rounded(x: ashari, y: ashari, w: ashari, h: ashari, roundness: ashari, segments: adad, color: adad) -> khali {
    rl_draw_rectangle_rounded(x, y, w, h, roundness, segments, color);
}
kar draw_rectangle_rounded_lines(x: ashari, y: ashari, w: ashari, h: ashari, roundness: ashari, segments: adad, color: adad) -> khali {
    rl_draw_rectangle_rounded_lines(x, y, w, h, roundness, segments, color);
}
kar draw_triangle(x1: ashari, y1: ashari, x2: ashari, y2: ashari, x3: ashari, y3: ashari, color: adad) -> khali {
    rl_draw_triangle(x1, y1, x2, y2, x3, y3, color);
}
kar draw_triangle_lines(x1: ashari, y1: ashari, x2: ashari, y2: ashari, x3: ashari, y3: ashari, color: adad) -> khali {
    rl_draw_triangle_lines(x1, y1, x2, y2, x3, y3, color);
}
kar draw_poly(cx: ashari, cy: ashari, sides: adad, radius: ashari, rotation: ashari, color: adad) -> khali {
    rl_draw_poly(cx, cy, sides, radius, rotation, color);
}
kar draw_poly_lines(cx: ashari, cy: ashari, sides: adad, radius: ashari, rotation: ashari, color: adad) -> khali {
    rl_draw_poly_lines(cx, cy, sides, radius, rotation, color);
}

# ================================================================
# COLLISION 2D
# ================================================================
kar check_collision_recs(x1: adad, y1: adad, w1: adad, h1: adad, x2: adad, y2: adad, w2: adad, h2: adad) -> adad {
    chu rl_check_collision_recs(x1, y1, w1, h1, x2, y2, w2, h2);
}
kar check_collision_circles(cx1: ashari, cy1: ashari, r1: ashari, cx2: ashari, cy2: ashari, r2: ashari) -> adad {
    chu rl_check_collision_circles(cx1, cy1, r1, cx2, cy2, r2);
}
kar check_collision_point_rec(px: ashari, py: ashari, x: adad, y: adad, w: adad, h: adad) -> adad {
