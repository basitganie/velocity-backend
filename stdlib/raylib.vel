# ================================================================
kar load_wave(path: lafz) -> adad {
    chu rl_load_wave(path);
}
kar is_wave_ready(wave: adad) -> adad {
    chu rl_is_wave_ready(wave);
}
kar unload_wave(wave: adad) -> khali {
    rl_unload_wave(wave);
}
kar load_sound_from_wave(wave: adad) -> adad {
    chu rl_load_sound_from_wave(wave);
}
kar export_wave(wave: adad, path: lafz) -> adad {
    chu rl_export_wave(wave, path);
}
kar update_sound(snd: adad, data: adad, n: adad) -> khali {
    rl_update_sound(snd, data, n);
}

